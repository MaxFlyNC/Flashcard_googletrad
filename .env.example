# ── Configuration FlashCardTrad ───────────────────────────────────────────────
# Copiez ce fichier : cp .env.example .env
# Puis modifiez les valeurs ci-dessous
#
# Ce serveur peut héberger plusieurs projets simultanément.
# Pour ajouter un projet : sudo ./scripts/add-project.sh <domaine> <conteneur:port>

# Domaine principal FlashCardTrad (pointant vers l'IP de votre VPS OVH)
DOMAIN=flashcardtrad.votredomaine.com

# Email pour Let's Encrypt (notifications d'expiration)
CERTBOT_EMAIL=votre@email.com

# Fuseau horaire
TIMEZONE=Europe/Paris

# ── API Backend ───────────────────────────────────────────────────────────────
# Token Bearer pour sécuriser l'API (utilisé par n8n et l'app React)
# Générez un token fort : openssl rand -hex 32
API_TOKEN=changez_ce_token_fort_ici

# ── n8n ───────────────────────────────────────────────────────────────────────
# Identifiants pour accéder à l'interface n8n (https://votredomaine.com/n8n/)
N8N_USER=admin
N8N_PASSWORD=changez_ce_mot_de_passe_fort_ici
